# ===== Hy3 / LLM 接入（必填）=====
# 默认走腾讯 TokenHub；也可切换 Novita 等服务商（均兼容 OpenAI Chat Completions）
HY3_API_KEY=sk-your-key-here
HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
HY3_MODEL=hy3
HY3_TIMEOUT=120

# ===== 检索源配置 =====
# 默认启用免 Key 的可靠学术源（开箱即跑、能真正检索到文献）
DEFAULT_SOURCES=openalex,crossref,arxiv
HTTP_TIMEOUT=20
MAX_SOURCES_PER_QUERY=6

# 可选增强：填入后启用 Semantic Scholar（限流更宽松、召回更稳）
# S2_API_KEY=
